{
  "env": {
    "vars": {
      "GH_TOKEN": "${GH_TOKEN}"
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "trustedProxies": [
      "172.16.0.0/12",
      "127.0.0.1",
      "::1"
    ],
    "controlUi": {
      "allowedOrigins": [
        "${OPENCLAW_CORS_ORIGIN}"
      ]
    },
    "auth": {
      "allowTailscale": true
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "allowFrom": [
        "${TELEGRAM_ADMIN_1}",
        "${TELEGRAM_ADMIN_2}",
        "${TELEGRAM_ADMIN_3}"
      ],
      "groups": {
        "-1003890684313": {
          "requireMention": true
        },
        "-1003788752801": {
          "requireMention": true
        }
      }
    }
  },
  "plugins": {
    "entries": {
      "codex": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      },
      "brave": {
        "enabled": true,
        "config": {
          "webSearch": {
            "mode": "web"
          }
        }
      }
    }
  },
  "skills": {
    "entries": {
      "browser-automation": {
        "enabled": true
      },
      "healthcheck": {
        "enabled": true
      },
      "taskflow": {
        "enabled": true
      },
      "weather": {
        "enabled": true
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "agents": {
    "defaults": {
      "contextLimits": {
        "memoryGetMaxChars": 2500,
        "memoryGetDefaultLines": 100,
        "toolResultMaxChars": 20000,
        "postCompactionMaxChars": 4000
      },
      "model": {
        "primary": "openai/gpt-5.5",
        "fallbacks": [
          "openai/gpt-5.4",
          "google/gemini-2.5-flash",
          "deepseek/deepseek-v4-flash"
        ]
      },
      "models": {
        "google/gemini-2.5-flash": {
          "alias": "gemini-flash-2.5"
        },
        "google/gemini-2.5-pro": {
          "alias": "gemini-pro-2.5"
        },
        "google/gemini-3.1-pro": {
          "alias": "gemini-pro-3.1"
        },
        "google/gemini-2.5-flash-image": {
          "alias": "gemini-flash-image-2.5"
        },
        "openai/gpt-5.4": {
          "alias": "openai-gpt-5.4",
          "agentRuntime": {
            "id": "codex"
          }
        },
        "openai/gpt-5.4-mini": {
          "alias": "openai-gpt-5.4-mini",
          "agentRuntime": {
            "id": "codex"
          }
        },
        "openai/gpt-5.5": {
          "alias": "openai-gpt-5.5",
          "agentRuntime": {
            "id": "codex"
          }
        },
        "openai/gpt-5.4-nano": {
          "alias": "openai-gpt-5.4-nano",
          "agentRuntime": {
            "id": "codex"
          }
        },
        "openai/gpt-image-1-mini": {
          "alias": "openai-gpt-image-1-mini",
          "agentRuntime": {
            "id": "codex"
          }
        },
        "deepseek/deepseek-v4-flash": {
          "alias": "deepseek-v4-flash"
        },
        "deepseek/deepseek-v4-pro": {
          "alias": "deepseek-v4-pro"
        },
        "qwen/qwen3.6-plus": {
          "alias": "qwen3.6-plus"
        },
        "qwen/qwen3-coder-plus": {
          "alias": "qwen3-coder-plus"
        },
        "zai/glm-5.1": {
          "alias": "zai-glm-5.1"
        },
        "zai/glm-4.7-flash": {
          "alias": "zai-glm-4.7-flash"
        },
        "litellm/claude-opus-4-6": {
          "alias": "litellm-claude-opus-4-6"
        },
        "litellm/claude-opus-4-7": {
          "alias": "litellm-claude-opus-4-7"
        },
        "litellm/claude-sonnet-4-6": {
          "alias": "litellm-claude-sonnet-4-6"
        }
      },
      "imageModel": {
        "primary": "openai/gpt-image-1-mini",
        "fallbacks": [
          "google/gemini-2.5-flash-image"
        ]
      },
      "imageGenerationModel": {
        "primary": "openai/gpt-image-1-mini",
        "fallbacks": [
          "google/gemini-2.5-flash-image"
        ]
      },
      "pdfModel": {
        "primary": "openai/gpt-5.4",
        "fallbacks": [
          "deepseek/deepseek-v4-flash",
          "google/gemini-2.5-flash"
        ]
      },
      "compaction": {
        "mode": "safeguard",
        "model": "openai/gpt-5.4-mini"
      },
      "heartbeat": {
        "every": "6h",
        "model": "openai/gpt-5.4-mini",
        "session": "main",
        "target": "telegram",
        "prompt": "Check: Any blockers, opportunities, or progress updates needed?"
      },
      "maxConcurrent": 1,
      "subagents": {
        "maxConcurrent": 2
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "ownerAllowFrom": [
      "telegram:1527378541"
    ]
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "auth": {
    "profiles": {
      "google:manual": {
        "provider": "google",
        "mode": "token"
      },
      "openai:oauth": {
        "provider": "openai",
        "mode": "oauth"
      },
      "litellm:apikey": {
        "provider": "litellm",
        "mode": "api_key"
      }
    },
    "order": {
      "google": [
        "google:manual"
      ],
      "openai": [
        "openai:oauth"
      ],
      "litellm": [
        "litellm:apikey"
      ]
    }
  },
  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "redactSensitive": "tools"
  },
  "tools": {
    "web": {
      "search": {
        "provider": "brave",
        "maxResults": 5,
        "timeoutSeconds": 30
      }
    }
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true
  }
}
